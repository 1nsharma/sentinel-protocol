{
  "name": "sentinel-protocol-v2",
  "version": "2.1.0",
  "description": "Enterprise-grade Digital Truth & Identity Framework",
  "main": "index.js",
  "scripts": {
    "start": "concurrently \"npm run api\" \"npm run blockchain\"",
    "api": "cd api && node server.js",
    "blockchain": "npx hardhat node",
    "test:contracts": "npx hardhat test",
    "deploy:ledger": "npx hardhat run scripts/deploy/deploy_ledger.js --network localhost"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "hardhat": "^2.19.1",
    "@nomicfoundation/hardhat-toolbox": "^4.0.0"
  },
  "dependencies": {
    "ethers": "^5.7.2"
  }
}
